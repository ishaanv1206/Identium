{
    "name": "identium-mcp",
    "version": "1.1.0",
    "description": "Unified Identium Identity Layer for AI Agents (Core + API + MCP)",
    "type": "module",
    "main": "dist/mcp/index.js",
    "bin": {
        "identium-mcp": "dist/mcp/index.js",
        "identium-api": "dist/api/index.js"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "npm run build && node dist/api/index.js",
        "build": "tsc",
        "start": "node dist/mcp/index.js",
        "api": "node dist/api/index.js",
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^0.6.0",
        "@prisma/client": "^5.21.1",
        "bech32": "^2.0.0",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "node-os-utils": "^2.0.1",
        "tweetnacl": "^1.0.3",
        "zod": "^3.23.8",
        "dotenv": "^16.4.7"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^24.10.1",
        "prisma": "^5.21.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}